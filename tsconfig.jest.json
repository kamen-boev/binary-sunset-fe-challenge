{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "Node16",
    "jsx": "react-jsx",

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "lib": ["DOM", "ES2020"],
    "types": ["jest", "node", "@testing-library/jest-dom", "vite/client"]
  },
  "include": ["src"]
}